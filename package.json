{
  "name": "simple-order-submission",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace @simple-order/api && npm run build --workspace @simple-order/web",
    "build:api": "npm run build --workspace @simple-order/api",
    "build:web": "npm run build --workspace @simple-order/web",
    "dev:api": "npm run dev --workspace @simple-order/api",
    "dev:web": "npm run dev --workspace @simple-order/web",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings=0",
    "start:api": "npm run start --workspace @simple-order/api",
    "test:api": "npm run test --workspace @simple-order/api",
    "typecheck": "tsc -p apps/api/tsconfig.json --noEmit && tsc -p packages/shared/tsconfig.json --noEmit && tsc -p apps/web/tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "eslint": "^9.12.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "globals": "^15.9.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.1"
  }
}
